{
  "name": "chatson",
  "version": "0.1.0",
  "description": "A fully client-side static web application that parses a WhatsApp Chat Export .zip file and displays geographic features as GeoJSON on a MapLibre GL JS map",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "preview": "vite preview --host",
    "build": "vite build"
  },
  "dependencies": {
    "@protomaps/basemaps": "^5.7.2",
    "@turf/truncate": "^7.3.4",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.21.0",
    "maplibre-gl-layer-control": "^0.14.1",
    "pmtiles": "^4.4.0"
  },
  "devDependencies": {
    "vite": "^8.0.2",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
